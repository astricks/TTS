#!/home/arvind/code/TTS/venv013/bin/python3
# EASY-INSTALL-ENTRY-SCRIPT: 'TTS==0.1.3','console_scripts','tts'
__requires__ = 'TTS==0.1.3'
import re
import sys
from pkg_resources import load_entry_point

if __name__ == '__main__':
    sys.argv[0] = re.sub(r'(-script\.pyw?|\.exe)?$', '', sys.argv[0])
    sys.exit(
        load_entry_point('TTS==0.1.3', 'console_scripts', 'tts')()
    )
